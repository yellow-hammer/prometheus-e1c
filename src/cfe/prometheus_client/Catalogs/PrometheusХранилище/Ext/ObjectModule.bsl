// Хранилище реестра по умолчанию (e1c: обход запрета Перем в общих модулях).
// Логика совпадает с prometheus CollectorRegistry / реестр по умолчанию.

// Реестр по умолчанию: Структура с ключом "Коллекторы" (массив коллекторов).
Перем РеестрПоУмолчанию;
// Массив старых коллекторов (структуры с полем Тип) для совместимости PrometheusRegistry.
Перем СтарыеКоллекторы;

Функция ПолучитьРеестрПоУмолчанию() Экспорт
	Если РеестрПоУмолчанию = Неопределено Тогда
		РеестрПоУмолчанию = Новый Структура("Коллекторы", Новый Массив);
	КонецЕсли;

	Возврат РеестрПоУмолчанию;
КонецФункции

Функция ПолучитьСтарыеКоллекторы() Экспорт
	Если СтарыеКоллекторы = Неопределено Тогда
		СтарыеКоллекторы = Новый Массив;
	КонецЕсли;

	Возврат СтарыеКоллекторы;
КонецФункции

Процедура ДобавитьСтарыйКоллектор(Коллектор) Экспорт
	ПолучитьСтарыеКоллекторы().Добавить(Коллектор);
КонецПроцедуры

Функция УдалитьСтарыйКоллектор(Коллектор) Экспорт
	Массив = ПолучитьСтарыеКоллекторы();
	Индекс = Массив.Найти(Коллектор);
	Если Индекс = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Массив.Удалить(Индекс);

	Возврат Истина;
КонецФункции
