// Реестр коллекторов Prometheus.
// В Коллекторы допускаются:
// - структуры метрик (поле Тип: counter, gauge, *_vector и т.д.) - сбор через PrometheusMetrics / PrometheusVec;
// - объекты с методом Collect(), возвращающим массив семейств (Имя, Тип, Справка, Сэмплы).

// Зарегистрировать коллектор.
//
// Параметры:
//   Реестр - Структура - реестр с ключом Коллекторы (массив).
//   Коллектор - Структура - структура метрики (поле Тип) или объект с методом Collect().
//
// Возвращаемое значение:
//   Булево - Истина.
Функция Register(Реестр, Коллектор) Экспорт
	Реестр.Коллекторы.Добавить(Коллектор);

	Возврат Истина;
КонецФункции

// Снять регистрацию коллектора.
//
// Параметры:
//   Реестр - Структура - реестр с ключом Коллекторы.
//   Коллектор - Структура, Объект - тот же экземпляр, что при регистрации.
//
// Возвращаемое значение:
//   Булево - Истина при успехе, Ложь если коллектор не был зарегистрирован.
Функция Unregister(Реестр, Коллектор) Экспорт
	Индекс = Реестр.Коллекторы.Найти(Коллектор);
	Если Индекс = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Реестр.Коллекторы.Удалить(Индекс);

	Возврат Истина;
КонецФункции

// Проверяет, что тип коллектора соответствует векторной метрике.
//
// Параметры:
//   ТипКоллектора - Строка - значение поля Тип структуры коллектора.
//
// Возвращаемое значение:
//   Булево - Истина, если это counter_vector, gauge_vector, histogram_vector или summary_vector.
Функция ЭтоВекторМетрик(ТипКоллектора)
	Возврат ТипКоллектора = "counter_vector" Или ТипКоллектора = "gauge_vector"
		Или ТипКоллектора = "histogram_vector" Или ТипКоллектора = "summary_vector";
КонецФункции

// Собирает сэмплы в семейства (как в OneScript PrometheusRegistry).
//
// Параметры:
//   Сэмплы - Массив - сэмплы промежуточного формата библиотеки.
//
// Возвращаемое значение:
//   Массив - семейства метрик: структуры с полями Имя, Тип, Справка, Сэмплы.
Функция СформироватьСемействаИзСэмплов(Сэмплы)
	СоответствиеСемейств = Новый Соответствие;
	Для Каждого Сэмпл Из Сэмплы Цикл
		Имя = Сэмпл.Имя;
		Семейство = СоответствиеСемейств.Получить(Имя);
		Если Семейство = Неопределено Тогда
			Семейство = Новый Структура;
			Семейство.Вставить("Имя", Имя);
			Семейство.Вставить("Тип", Сэмпл.Тип);
			Семейство.Вставить("Справка", Сэмпл.Справка);
			Семейство.Вставить("Сэмплы", Новый Массив);
			СоответствиеСемейств.Вставить(Имя, Семейство);
		КонецЕсли;

		СэмплДляСемейства = Новый Структура(
			"ИмяСэмпла, Лейблы, Значение",
			Сэмпл.ИмяСэмпла, Сэмпл.Лейблы, Сэмпл.Значение);
		Если Сэмпл.Свойство("Квантиль") Тогда
			СэмплДляСемейства.Вставить("Квантиль", Сэмпл.Квантиль);
		КонецЕсли;

		Если Сэмпл.Свойство("ВерхняяГраница") Тогда
			СэмплДляСемейства.Вставить("ВерхняяГраница", Сэмпл.ВерхняяГраница);
		КонецЕсли;

		Семейство.Сэмплы.Добавить(СэмплДляСемейства);
	КонецЦикла;

	Семейства = Новый Массив;
	Для Каждого КлючИЗначение Из СоответствиеСемейств Цикл
		Семейства.Добавить(КлючИЗначение.Значение);
	КонецЦикла;

	Возврат Семейства;
КонецФункции

// Собрать метрики со всех зарегистрированных коллекторов.
//
// Параметры:
//   Реестр - Структура - реестр с ключом Коллекторы.
//
// Возвращаемое значение:
//   Массив из Структура - семейства метрик (Имя, Тип, Справка, Сэмплы).
Функция Gather(Реестр) Экспорт
	ВсеСемейства = Новый Массив;
	Если Реестр.Коллекторы = Неопределено Тогда
		Возврат ВсеСемейства;
	КонецЕсли;
	Для Каждого Коллектор Из Реестр.Коллекторы Цикл
		Если ТипЗнч(Коллектор) = Тип("Структура") И Коллектор.Свойство("Тип") Тогда
			РезультатСэмплов = Новый Массив;
			Если ЭтоВекторМетрик(Коллектор.Тип) Тогда
				PrometheusVec.СобратьВектор(Коллектор, РезультатСэмплов);
			Иначе
				PrometheusMetrics.СобратьКоллектор(Коллектор, РезультатСэмплов);
			КонецЕсли;
			Семейства = СформироватьСемействаИзСэмплов(РезультатСэмплов);
			Для Каждого Семейство Из Семейства Цикл
				ВсеСемейства.Добавить(Семейство);
			КонецЦикла;
		Иначе
			Семейства = Коллектор.Collect();
			Для Каждого Семейство Из Семейства Цикл
				ВсеСемейства.Добавить(Семейство);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	Возврат ВсеСемейства;
КонецФункции

// Создать новую структуру реестра (Коллекторы - массив).
//
// Возвращаемое значение:
//   Структура - реестр с ключом Коллекторы (массив).
Функция СоздатьРеестр() Экспорт
	Возврат Новый Структура("Коллекторы", Новый Массив);
КонецФункции
