// Реестр метрик Prometheus. Использует переданную структуру реестра (Коллекторы, СтарыеКоллекторы);
// поддерживает старые коллекторы (структуры с Тип).

Функция ЭтоВектор(ТипКоллектора)
	Возврат ТипКоллектора = "counter_vector" Или ТипКоллектора = "gauge_vector"
		Или ТипКоллектора = "histogram_vector" Или ТипКоллектора = "summary_vector";
КонецФункции

Функция СформироватьСемействаИзСэмплов(Сэмплы)
	СоответствиеСемейств = Новый Соответствие;
	Для Каждого Сэмпл Из Сэмплы Цикл
		Имя = Сэмпл.Имя;
		Семейство = СоответствиеСемейств.Получить(Имя);
		Если Семейство = Неопределено Тогда
			Семейство = Новый Структура;
			Семейство.Вставить("Имя", Имя);
			Семейство.Вставить("Тип", Сэмпл.Тип);
			Семейство.Вставить("Справка", Сэмпл.Справка);
			Семейство.Вставить("Сэмплы", Новый Массив);
			СоответствиеСемейств.Вставить(Имя, Семейство);
		КонецЕсли;

		СэмплДляСемейства = Новый Структура(
			"ИмяСэмпла, Лейблы, Значение",
			Сэмпл.ИмяСэмпла, Сэмпл.Лейблы, Сэмпл.Значение);
		Если Сэмпл.Свойство("Квантиль") Тогда
			СэмплДляСемейства.Вставить("Квантиль", Сэмпл.Квантиль);
		КонецЕсли;

		Если Сэмпл.Свойство("ВерхняяГраница") Тогда
			СэмплДляСемейства.Вставить("ВерхняяГраница", Сэмпл.ВерхняяГраница);
		КонецЕсли;

		Семейство.Сэмплы.Добавить(СэмплДляСемейства);
	КонецЦикла;

	Семейства = Новый Массив;
	Для Каждого КлючИЗначение Из СоответствиеСемейств Цикл
		Семейства.Добавить(КлючИЗначение.Значение);
	КонецЦикла;

	Возврат Семейства;
КонецФункции

Функция Зарегистрировать(Реестр, Коллектор) Экспорт
	Если ТипЗнч(Коллектор) = Тип("Структура") И Коллектор.Свойство("Тип") Тогда
		Реестр.СтарыеКоллекторы.Добавить(Коллектор);

		Возврат Истина;
	КонецЕсли;

	Возврат PrometheusCollectorRegistry.Register(Реестр, Коллектор);
КонецФункции

Функция СнятьРегистрацию(Реестр, Коллектор) Экспорт
	Если ТипЗнч(Коллектор) = Тип("Структура") Тогда
		Индекс = Реестр.СтарыеКоллекторы.Найти(Коллектор);
		Если Индекс <> Неопределено Тогда
			Реестр.СтарыеКоллекторы.Удалить(Индекс);

			Возврат Истина;
		КонецЕсли;
	КонецЕсли;

	Возврат PrometheusCollectorRegistry.Unregister(Реестр, Коллектор);
КонецФункции

Процедура ЗарегистрироватьОбязательно(Реестр, Коллектор) Экспорт
	Успех = Зарегистрировать(Реестр, Коллектор);
	Если Не Успех Тогда
		ВызватьИсключение "Не удалось зарегистрировать коллектор метрик";
	КонецЕсли;
КонецПроцедуры

Функция Собрать(Реестр) Экспорт
	Результат = PrometheusCollectorRegistry.Gather(Реестр);
	Если Реестр.СтарыеКоллекторы.Количество() > 0 Тогда
		Для Каждого Коллектор Из Реестр.СтарыеКоллекторы Цикл
			РезультатСэмплов = Новый Массив;
			Если ЭтоВектор(Коллектор.Тип) Тогда
				PrometheusVec.СобратьВектор(Коллектор, РезультатСэмплов);
			Иначе
				PrometheusMetrics.СобратьКоллектор(Коллектор, РезультатСэмплов);
			КонецЕсли;

			Семейства = СформироватьСемействаИзСэмплов(РезультатСэмплов);
			Для Каждого Семейство Из Семейства Цикл
				Результат.Добавить(Семейство);
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;

	Возврат Результат;
КонецФункции
