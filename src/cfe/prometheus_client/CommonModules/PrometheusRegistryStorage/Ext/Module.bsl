// Хранение реестра по умолчанию (e1c). В OneScript: CollectorRegistry в PrometheusRegistry;
// здесь - структура в справочнике PrometheusХранилище (реквизит ДанныеРеестра).
// Обход запрета Перем в общих модулях и HTTP-сервисе.

// Возвращает реестр: структура с ключами "Коллекторы", "СтарыеКоллекторы" (массивы).
// При первом обращении или пустом хранилище создаёт новый реестр с встроенными метриками.
// Для старых реестров дополняет встроенными метриками (app_up, metrics_requests_total), если их нет.
//
// Возвращаемое значение:
//   Структура - реестр с ключами Коллекторы, СтарыеКоллекторы (массивы).
Функция ПолучитьРеестр() Экспорт
	Ссылка = Справочники.PrometheusХранилище.РеестрПоУмолчанию;
	Объект = Ссылка.ПолучитьОбъект();

	Хранилище = Объект.ДанныеРеестра;
	Если Хранилище = Неопределено Или НЕ ТипЗнч(Хранилище) = Тип("ХранилищеЗначения") Тогда
		Реестр = СоздатьРеестрСВстроеннойМетрикой();
		СохранитьРеестр(Реестр);
		Возврат Реестр;
	КонецЕсли;

	Реестр = Хранилище.Получить();
	Если Реестр = Неопределено Тогда
		Реестр = СоздатьРеестрСВстроеннойМетрикой();
		СохранитьРеестр(Реестр);
	Иначе
		ДополнитьВстроеннымиМетриками(Реестр);
	КонецЕсли;

	Возврат Реестр;
КонецФункции

// Создаёт новый реестр и добавляет встроенные метрики (как в prometheus-metrics: app_up, metrics_requests_total).
//
// Возвращаемое значение:
//   Структура - реестр с ключами Коллекторы, СтарыеКоллекторы (массивы).
Функция СоздатьРеестрСВстроеннойМетрикой()
	Реестр = Новый Структура("Коллекторы, СтарыеКоллекторы", Новый Массив, Новый Массив);
	ДобавитьВстроенныеМетрикиВРеестр(Реестр);

	Возврат Реестр;
КонецФункции

// Добавляет app_up и metrics_requests_total в реестр, если их ещё нет. После изменений сохраняет реестр.
//
// Параметры:
//   Реестр - Структура - реестр с ключами Коллекторы, СтарыеКоллекторы (массивы).
Процедура ДополнитьВстроеннымиМетриками(Реестр)
	ЕстьAppUp = Ложь;
	ЕстьСчетчикЗапросов = Ложь;
	Для Каждого Коллектор Из Реестр.СтарыеКоллекторы Цикл
		Если ТипЗнч(Коллектор) = Тип("Структура") И Коллектор.Свойство("Имя") Тогда
			Если Коллектор.Имя = "app_up" Тогда
				ЕстьAppUp = Истина;
			КонецЕсли;
			Если Коллектор.Имя = "metrics_requests_total" Тогда
				ЕстьСчетчикЗапросов = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Если ЕстьAppUp И ЕстьСчетчикЗапросов Тогда
		Возврат;
	КонецЕсли;

	ДобавитьВстроенныеМетрикиВРеестр(Реестр);
	СохранитьРеестр(Реестр);
КонецПроцедуры

// Добавляет в реестр метрики app_up (gauge 1) и metrics_requests_total (counter). Не сохраняет.
//
// Параметры:
//   Реестр - Структура - реестр с ключами Коллекторы, СтарыеКоллекторы.
Процедура ДобавитьВстроенныеМетрикиВРеестр(Реестр)
	Если НайтиКоллекторПоИмени(Реестр, "app_up") = Неопределено Тогда
		ИндикаторПриложения = PrometheusMetrics.НовыйИндикатор(
			Новый Структура("Имя, Справка", "app_up", "Приложение запущено (1)"));
		PrometheusMetrics.УстановитьИндикатор(ИндикаторПриложения, 1);
		PrometheusRegistry.Зарегистрировать(Реестр, ИндикаторПриложения);
	КонецЕсли;

	Если НайтиКоллекторПоИмени(Реестр, "metrics_requests_total") = Неопределено Тогда
		СчетчикЗапросов = PrometheusMetrics.НовыйСчетчик(
			Новый Структура("Имя, Справка", "metrics_requests_total", "Число запросов к эндпоинту /metrics"));
		PrometheusRegistry.Зарегистрировать(Реестр, СчетчикЗапросов);
	КонецЕсли;
КонецПроцедуры

// Ищет в реестре коллектор с заданным именем (СтарыеКоллекторы).
//
// Параметры:
//   Реестр - Структура - реестр с ключами Коллекторы, СтарыеКоллекторы (массивы).
//   Имя - Строка - имя метрики (например, "app_up").
//
// Возвращаемое значение:
//   Структура, Неопределено - коллектор или Неопределено.
Функция НайтиКоллекторПоИмени(Реестр, Имя)
	Для Каждого Коллектор Из Реестр.СтарыеКоллекторы Цикл
		Если ТипЗнч(Коллектор) = Тип("Структура") И Коллектор.Свойство("Имя") И Коллектор.Имя = Имя Тогда
			Возврат Коллектор;
		КонецЕсли;
	КонецЦикла;

	Возврат Неопределено;
КонецФункции

// Сохраняет реестр в реквизит ДанныеРеестра предопределённого элемента РеестрПоУмолчанию.
// Реестр должен быть сериализуемым (коллекторы - структуры с примитивными данными).
//
// Параметры:
//   Реестр - Структура - реестр с ключами Коллекторы, СтарыеКоллекторы.
Процедура СохранитьРеестр(Реестр) Экспорт
	Ссылка = Справочники.PrometheusХранилище.РеестрПоУмолчанию;
	Объект = Ссылка.ПолучитьОбъект();

	Хранилище = Новый ХранилищеЗначения(Реестр);
	Объект.ДанныеРеестра = Хранилище;
	Объект.Записать();
КонецПроцедуры
