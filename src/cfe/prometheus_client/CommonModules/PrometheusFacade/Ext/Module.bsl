// Фасад: дефолтный реестр и фабрики метрик с автоматической регистрацией.
// Ядро - PrometheusRegistry, PrometheusMetrics, PrometheusVec (без HTTP).
// Реестр по умолчанию: PrometheusRegistryStorage.ПолучитьРеестр() (e1c: РС PrometheusДанныеРеестра).
// Передавайте в СобратьМетрики при необходимости.

Функция РеестрПоУмолчанию() Экспорт
	Возврат PrometheusRegistryStorage.ПолучитьРеестр();
КонецФункции

// --- Скалярные метрики (счётчик, индикатор, гистограмма, резюме) ---

Функция НовыйСчетчик(Имя, Справка = "", КонстантныеЛейблы = Неопределено) Экспорт
	Опции = Новый Структура("Имя, Справка", Имя, Справка);
	Если ТипЗнч(КонстантныеЛейблы) = Тип("Соответствие") Тогда
		Опции.Вставить("КонстантныеЛейблы", КонстантныеЛейблы);
	КонецЕсли;

	Реестр = РеестрПоУмолчанию();
	Счетчик = PrometheusMetrics.НовыйСчетчик(Опции);
	PrometheusRegistry.ЗарегистрироватьОбязательно(Реестр, Счетчик);
	PrometheusRegistryStorage.СохранитьРеестр(Реестр);

	Возврат Счетчик;
КонецФункции

Функция НовыйИндикатор(Имя, Справка = "", КонстантныеЛейблы = Неопределено) Экспорт
	Опции = Новый Структура("Имя, Справка", Имя, Справка);
	Если ТипЗнч(КонстантныеЛейблы) = Тип("Соответствие") Тогда
		Опции.Вставить("КонстантныеЛейблы", КонстантныеЛейблы);
	КонецЕсли;

	Реестр = РеестрПоУмолчанию();
	Индикатор = PrometheusMetrics.НовыйИндикатор(Опции);
	PrometheusRegistry.ЗарегистрироватьОбязательно(Реестр, Индикатор);
	PrometheusRegistryStorage.СохранитьРеестр(Реестр);

	Возврат Индикатор;
КонецФункции

Функция НоваяГистограмма(Имя, Справка = "", ВерхниеГраницыБакетов = Неопределено,
		КонстантныеЛейблы = Неопределено) Экспорт
	Границы = ?(ТипЗнч(ВерхниеГраницыБакетов) = Тип("Массив"), ВерхниеГраницыБакетов, Новый Массив);
	Опции = Новый Структура("Имя, Справка, ВерхниеГраницыБакетов", Имя, Справка, Границы);
	Если ТипЗнч(КонстантныеЛейблы) = Тип("Соответствие") Тогда
		Опции.Вставить("КонстантныеЛейблы", КонстантныеЛейблы);
	КонецЕсли;

	Реестр = РеестрПоУмолчанию();
	Гистограмма = PrometheusMetrics.НоваяГистограмма(Опции);
	PrometheusRegistry.ЗарегистрироватьОбязательно(Реестр, Гистограмма);
	PrometheusRegistryStorage.СохранитьРеестр(Реестр);

	Возврат Гистограмма;
КонецФункции

