// --- Экземпляр по лейблам (вектор → счётчик/индикатор/гистограмма/резюме с заданными лейблами) ---
// ЗначенияЛейблов: массив в порядке имён лейблов или Соответствие (имя → значение).

Функция СчетчикСЛейблами(ВекторСчетчика, ЗначенияЛейблов) Экспорт
	Возврат PrometheusVec.СчетчикВекторСМетками(ВекторСчетчика, ЗначенияЛейблов);
КонецФункции

Функция ИндикаторСЛейблами(ВекторИндикатора, ЗначенияЛейблов) Экспорт
	Возврат PrometheusVec.ИндикаторВекторСМетками(ВекторИндикатора, ЗначенияЛейблов);
КонецФункции

Функция ГистограммаСЛейблами(ВекторГистограммы, ЗначенияЛейблов) Экспорт
	Возврат PrometheusVec.ГистограммаВекторСМетками(ВекторГистограммы, ЗначенияЛейблов);
КонецФункции

Функция РезюмеСЛейблами(ВекторРезюме, ЗначенияЛейблов) Экспорт
	Возврат PrometheusVec.РезюмеВекторСМетками(ВекторРезюме, ЗначенияЛейблов);
КонецФункции

// --- Сбор и экспорт ---

Функция СобратьМетрики(Реестр = Неопределено) Экспорт
	Если Реестр = Неопределено Тогда
		Реестр = РеестрПоУмолчанию();
	КонецЕсли;

	Возврат PrometheusRegistry.Собрать(Реестр);
КонецФункции

Функция СериализоватьВТекст(Семейства) Экспорт
	Возврат PrometheusTextFormat.Сериализовать(Семейства);
КонецФункции

Функция ContentTypeМетрик() Экспорт
	Возврат PrometheusTextFormat.ContentType();
КонецФункции

// --- Операции над метриками (единая точка входа, без подключения PrometheusMetrics) ---

Процедура Инкремент(Метрика) Экспорт
	Если Метрика.Тип = "counter" Тогда
		PrometheusMetrics.ИнкрементСчетчика(Метрика);
	ИначеЕсли Метрика.Тип = "gauge" Тогда
		PrometheusMetrics.ИнкрементИндикатора(Метрика);
	Иначе
		ВызватьИсключение "Инкремент применим только к counter или gauge, получен: " + Метрика.Тип;
	КонецЕсли;
КонецПроцедуры

Процедура Добавить(Метрика, Значение) Экспорт
	Если Метрика.Тип = "counter" Тогда
		PrometheusMetrics.ДобавитьКСчетчику(Метрика, Значение);
	ИначеЕсли Метрика.Тип = "gauge" Тогда
		PrometheusMetrics.ДобавитьКИндикатору(Метрика, Значение);
	Иначе
		ВызватьИсключение "Добавить применим только к counter или gauge, получен: " + Метрика.Тип;
	КонецЕсли;
КонецПроцедуры

Процедура Установить(Метрика, Значение) Экспорт
	Если Метрика.Тип = "gauge" Тогда
		PrometheusMetrics.УстановитьИндикатор(Метрика, Значение);
	Иначе
		ВызватьИсключение "Установить применим только к gauge, получен: " + Метрика.Тип;
	КонецЕсли;
КонецПроцедуры

Процедура Декремент(Метрика) Экспорт
	Если Метрика.Тип = "gauge" Тогда
		PrometheusMetrics.ДекрементИндикатора(Метрика);
	Иначе
		ВызватьИсключение "Декремент применим только к gauge, получен: " + Метрика.Тип;
	КонецЕсли;
КонецПроцедуры

Процедура Вычесть(Метрика, Значение) Экспорт
	Если Метрика.Тип = "gauge" Тогда
		PrometheusMetrics.ВычестьИзИндикатора(Метрика, Значение);
	Иначе
		ВызватьИсключение "Вычесть применим только к gauge, получен: " + Метрика.Тип;
	КонецЕсли;
КонецПроцедуры

Процедура Наблюдать(Метрика, Значение) Экспорт
	Если Метрика.Тип = "histogram" Тогда
		PrometheusMetrics.НаблюдатьГистограмму(Метрика, Значение);
	ИначеЕсли Метрика.Тип = "summary" Тогда
		PrometheusMetrics.НаблюдатьРезюме(Метрика, Значение);
	Иначе
		ВызватьИсключение "Наблюдать применим только к histogram или summary, получен: " + Метрика.Тип;
	КонецЕсли;
КонецПроцедуры
