// Реестр: PrometheusRegistryStorage.ПолучитьРеестр().
// Сбор и сериализация - как в OneScript (Prometheus.СобратьМетрики, СериализоватьВТекст).

Функция DefaultGetMetrics(Запрос)
	КодОтветаУспех = 200;

	РеестрМетрик = PrometheusRegistryStorage.ПолучитьРеестр();
	УвеличитьСчетчикЗапросовМетрик(РеестрМетрик);
	Семейства = PrometheusFacade.СобратьМетрики(РеестрМетрик);
	Текст = PrometheusFacade.СериализоватьВТекст(Семейства);

	Ответ = Новый HTTPСервисОтвет(КодОтветаУспех);
	Ответ.УстановитьТелоИзСтроки(Текст);
	Ответ.Заголовки.Вставить("Content-Type", PrometheusFacade.ContentTypeМетрик());

	Возврат Ответ;
КонецФункции

// Увеличивает встроенный счётчик prometheus_client_http_requests_total и сохраняет реестр.
//
// Параметры:
//   Реестр - Структура - реестр с ключом Коллекторы (массив).
Процедура УвеличитьСчетчикЗапросовМетрик(Реестр)
	Для Каждого Коллектор Из Реестр.Коллекторы Цикл
		Если ТипЗнч(Коллектор) = Тип("Структура") 
			И Коллектор.Свойство("Имя") 
			И Коллектор.Имя = "prometheus_client_http_requests_total" Тогда
			PrometheusFacade.Инкремент(Коллектор);
			PrometheusRegistryStorage.СохранитьРеестр(Реестр);
			Возврат;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
