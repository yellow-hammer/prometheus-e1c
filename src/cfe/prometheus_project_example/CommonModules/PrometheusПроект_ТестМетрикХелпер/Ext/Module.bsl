// Счётчик нажатий кнопки на форме теста метрик (для проверки GET /metrics).
// Ссылку на счётчик не храним (Перем в этом модуле запрещён), получаем по имени из реестра.
// После инкремента реестр сохраняется в БД; актуальное значение - в ответе следующего запроса к /metrics.
// Обновите страницу при необходимости.

// Увеличивает тестовый счётчик на 1. Вызывать с формы при нажатии кнопки.
Процедура УвеличитьСчетчикНажатий() Экспорт
	ИмяМетрики = "test_form_clicks_total";
	
	// Всегда берём реестр заново и сохраняем после изменения, чтобы /metrics видел актуальные данные.
	Реестр = PrometheusRegistryStorage.ПолучитьРеестр();
	Счетчик = ПолучитьСчетчикПоИмениВРеестре(Реестр, ИмяМетрики);
	
	Если Счетчик = Неопределено Тогда
		PrometheusFacade.НовыйСчетчик(ИмяМетрики, "Число нажатий кнопки на форме теста метрик");
		Реестр = PrometheusRegistryStorage.ПолучитьРеестр();
		Счетчик = ПолучитьСчетчикПоИмениВРеестре(Реестр, ИмяМетрики);
	КонецЕсли;
	
	PrometheusFacade.Инкремент(Счетчик);
	PrometheusRegistryStorage.СохранитьРеестр(Реестр);
КонецПроцедуры

// Ищет в переданном реестре коллектор с заданным именем.
//
// Параметры:
//   Реестр - Структура - реестр с ключом Коллекторы.
//   Имя - Строка - имя метрики.
//
// Возвращаемое значение:
//   Структура, Неопределено - коллектор с полем Имя или Неопределено.
Функция ПолучитьСчетчикПоИмениВРеестре(Реестр, Имя)
	
	Для Каждого Коллектор Из Реестр.Коллекторы Цикл
		Если ТипЗнч(Коллектор) = Тип("Структура") И Коллектор.Свойство("Имя") И Коллектор.Имя = Имя Тогда
			Возврат Коллектор;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
КонецФункции
